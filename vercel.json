{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.ts": {
      "maxDuration": 10,
      "memory": 512,
      "includeFiles": "api/ship_tracks_2021-10-01_to_2021-10-01_191ships_207803positions.csv"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
